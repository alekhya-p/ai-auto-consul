# Copy to web/.env.local for local development.
#
# All six Firebase keys are required together for auth flows.
# For UI-only work without sign-in, use: npm run dev:mock

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: reCAPTCHA Enterprise site key (App Check in production-like setups)
VITE_RECAPTCHA_SITE_KEY=

# Optional: App Check debug token for local dev (whitelist in Firebase Console)
VITE_APPCHECK_DEBUG_TOKEN=

# Optional: require verified email before Stripe checkout (production uses true)
VITE_REQUIRE_EMAIL_VERIFY=false
